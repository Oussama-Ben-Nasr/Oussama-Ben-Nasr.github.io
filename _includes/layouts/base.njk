<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description or 'A developer blog about code, craft, and curiosity.' }}">
  <title>{% if title %}{{ title }} — {% endif %}Oussama Ben Nasr</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="alternate" type="application/rss+xml" title="Oussama Ben Nasr" href="/feed.xml">
</head>
<body>

<nav class="nav">
  <a href="/" class="nav-logo">Oussama Ben Nasr</a>
  <ul class="nav-links">
    <li><a href="/" {% if page.url == "/" %}class="active"{% endif %}>Home</a></li>
    <li><a href="/posts/" {% if "/posts/" in page.url %}class="active"{% endif %}>Posts</a></li>
    <li><a href="/about/" {% if page.url == "/about/" %}class="active"{% endif %}>About</a></li>
    <li><a href="/feed.xml">RSS</a></li>
  </ul>
</nav>

<main>
  {{ content | safe }}
</main>

<footer class="footer">
  <p>© 2024 Oussama Ben Nasr. Built with Eleventy.</p>
  <ul class="footer-links">
    <li><a href="https://github.com/Oussama-Ben-Nasr" target="_blank" rel="noopener">GitHub</a></li>
    <li><a href="/feed.xml">RSS</a></li>
  </ul>
</footer>

</body>
</html>
